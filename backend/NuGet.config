<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet.Config — ControlService Backend
  ======================================
  Este arquivo existe para garantir que o build dentro de contêineres Docker
  (Linux/Alpine) não tente resolver o caminho de fallback do Visual Studio
  Windows: 'C:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages'.
  
  Ao limpar explicitamente o <fallbackPackageFolders>, o NuGet usa apenas
  o cache interno do contêiner, tornando o build 100% portátil.
-->
<configuration>
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
</configuration>
